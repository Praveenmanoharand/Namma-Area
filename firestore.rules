rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Common security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'official'
      );
    }

    // 1. Users Profile Collection
    match /users/{userId} {
      // Anyone can read profiles so names/avatars render properly
      allow read: if true;
      // Users can ONLY edit (create/update) their own profile
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // 2. Complaints Collection
    match /complaints/{complaintId} {
      // Anyone logged in can read complaints
      allow read: if isSignedIn();
      // Only authenticated users can create complaints
      allow create: if isSignedIn();
      // Only creator or admin can delete
      allow delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());
      
      // Update rules: Creator can edit anything, others can only upvote/downvote
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isAdmin() ||
        (
          // Check that only upvotes and upvotedBy are being modified
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'upvotedBy']) &&
          (
            (
              // Upvoting: user adds themselves and increments upvotes by 1
              !(request.auth.uid in resource.data.upvotedBy) &&
              (request.auth.uid in request.resource.data.upvotedBy) &&
              request.resource.data.upvotes == resource.data.upvotes + 1 &&
              request.resource.data.upvotedBy.size() == resource.data.upvotedBy.size() + 1
            ) ||
            (
              // Downvoting: user removes themselves and decrements upvotes by 1
              (request.auth.uid in resource.data.upvotedBy) &&
              !(request.auth.uid in request.resource.data.upvotedBy) &&
              request.resource.data.upvotes == resource.data.upvotes - 1 &&
              request.resource.data.upvotedBy.size() == resource.data.upvotedBy.size() - 1
            )
          )
        )
      );

      // Comments subcollection: complaints/{complaintId}/comments/{commentId}
      match /comments/{commentId} {
        allow read: if isSignedIn();
        // Comments can be added by any authenticated user
        allow create: if isSignedIn();
        // Comments can only be deleted by comment owner or complaint owner (or admin)
        allow delete: if isSignedIn() && (
          resource.data.authorId == request.auth.uid ||
          get(/databases/$(database)/documents/complaints/$(complaintId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    // 3. Jobs Collection
    match /jobs/{jobId} {
      // Anyone can read jobs
      allow read: if true;
      // Only authenticated users can create jobs
      allow create: if isSignedIn();
      // Only job creator or admin can delete/update
      allow update, delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    // 4. Polls Collection
    match /polls/{pollId} {
      // Anyone can read polls
      allow read: if true;
      // Only admin can create or delete polls
      allow create, delete: if isAdmin();
      // Admin can update, or users can update options/totalVotes/userVotes during voting
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['options', 'totalVotes', 'userVotes'])
      );

      // Votes subcollection: polls/{pollId}/votes/{userId}
      match /votes/{userId} {
        allow read: if isSignedIn();
        // Users can vote only once per poll
        allow create, update, delete: if isOwner(userId);
      }
    }

    // 5. Lost & Found Collection
    match /lost_found/{itemId} {
      allow read: if true;
      // Authenticated users can create items
      allow create: if isSignedIn();
      // Only owner can edit/delete
      allow update, delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    // 6. Emergency Contacts
    match /emergency_contacts/{contactId} {
      // Read only for everyone
      allow read: if true;
      // Only admin can update
      allow write: if isAdmin();
    }

    // 7. Announcements
    match /announcements/{announcementId} {
      // Read only for users
      allow read: if true;
      // Only admin can create/update
      allow write: if isAdmin();
    }

    // Support other features of the platform
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /suggestions/{sugId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /volunteer_events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /volunteer_profiles/{profileId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /groups/{groupId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /group_posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /impact_items/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /leaderboard_users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /ward_projects/{projectId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
